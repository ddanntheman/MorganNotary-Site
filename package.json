{
  "name": "morgannotary-website",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Marketing website for Morgan Danner, Notary LLC — Richmond, VA.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro check && astro build",
    "preview": "astro preview --host",
    "astro": "astro",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "astro check && tsc --noEmit",
    "validate:nap": "node scripts/validate-nap.mjs",
    "validate:upl": "node scripts/check-upl.mjs",
    "validate:all": "pnpm typecheck && pnpm lint && pnpm validate:nap && pnpm validate:upl"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/react": "^4.1.0",
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "@iconify-json/lucide": "^1.2.0",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.1.0",
    "astro-icon": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "schema-dts": "^1.1.0",
    "tailwindcss": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^1.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
