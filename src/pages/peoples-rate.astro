---
import { getEntry, render } from "astro:content";
import Breadcrumb from "@components/sections/Breadcrumb.astro";
import CtaStrip from "@components/sections/CtaStrip.astro";
import Alert from "@components/ui/Alert.astro";
import Card from "@components/ui/Card.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { breadcrumbJsonLd } from "@lib/schema";
import { absUrl, buildMeta } from "@lib/seo";
import { Icon } from "astro-icon/components";

const entry = await getEntry("site", "peoples-rate");
if (!entry) throw new Error("Missing site/peoples-rate.mdx");
const { Content } = await render(entry);

const groups = [
  { title: "Veterans", body: "All branches, active duty or retired. Thank you." },
  { title: "LGBTQ+ community", body: "Family, couples, and individuals across the spectrum." },
  { title: "Single parents", body: "Raising kids on your own is the whole job. Discount's yours." },
  { title: "Artists & activists", body: "People who build what Richmond actually is." },
  { title: "Seniors 65+", body: "Decades of contribution. Small thank-you from me." },
  {
    title: "Immigrants / DACA",
    body: "Apostille, immigration paperwork, and everyday notary needs.",
  },
];

const meta = buildMeta({
  title: entry.data.seo.title,
  description: entry.data.seo.description,
  path: "/peoples-rate",
});

const jsonLd = [
  breadcrumbJsonLd([
    { name: "Home", url: absUrl("/") },
    { name: "The People's Rate", url: absUrl("/peoples-rate") },
  ]),
];
---

<BaseLayout meta={meta} jsonLd={jsonLd}>
  <Breadcrumb items={[
    { name: "Home", url: "/" },
    { name: "The People's Rate", url: "/peoples-rate" },
  ]} />

  <section class="section-tight bg-[color:var(--color-charcoal)] text-white">
    <div class="container-brand max-w-3xl">
      <p class="eyebrow eyebrow-neon mb-3">The People's Rate</p>
      <h1 class="font-display text-4xl sm:text-5xl text-white">{entry.data.h1}</h1>
      <p class="mt-4 text-lg text-white/80">{entry.data.subhead}</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-brand max-w-4xl grid sm:grid-cols-2 gap-4">
      {
        groups.map((g) => (
          <Card>
            <div class="flex items-start gap-3">
              <Icon name="lucide:heart-handshake" class="size-5 text-[color:var(--color-plum)] shrink-0 mt-1" />
              <div>
                <h2 class="font-display text-xl">{g.title}</h2>
                <p class="text-sm text-[color:var(--color-text-secondary)] mt-1">{g.body}</p>
              </div>
            </div>
          </Card>
        ))
      }
    </div>
  </section>

  <section class="section-tight">
    <div class="container-brand max-w-3xl">
      <div class="grid sm:grid-cols-2 gap-4">
        <Card>
          <p class="eyebrow mb-2">Tier 1 · Travel discount</p>
          <p class="font-display text-3xl">50% off travel</p>
          <p class="mt-2 text-sm text-[color:var(--color-text-secondary)]">
            Within 20 miles of downtown Richmond. Direct bookings only.
          </p>
        </Card>
        <Card variant="dark">
          <p class="eyebrow eyebrow-neon mb-2">Tier 2 · Service discount</p>
          <p class="font-display text-3xl text-white">+10% off notary fee</p>
          <p class="mt-2 text-sm text-white/70">
            Stacks on Tier 1 when you fall into both categories. Direct bookings only.
          </p>
        </Card>
      </div>
      <div class="mt-10 prose-brand">
        <Content />
      </div>
      <Alert tone="info" title="How to use it" class="mt-6">
        Mention it when you book — no documentation required. Honor system.
        If the signing is arranged through a title company, attorney, or
        any professional platform, standard rates apply.
      </Alert>
    </div>
  </section>

  <CtaStrip
    heading="Book direct. Mention The People's Rate."
    body="I'll confirm availability and the all-in price within the hour."
  />
</BaseLayout>
