---
import { getCollection, getEntry } from "astro:content";
import AreasGrid from "@components/sections/AreasGrid.astro";
import CtaStrip from "@components/sections/CtaStrip.astro";
import FaqAccordion from "@components/sections/FaqAccordion.astro";
import Hero from "@components/sections/Hero.astro";
import ServicesGrid from "@components/sections/ServicesGrid.astro";
import TestimonialsStrip from "@components/sections/TestimonialsStrip.astro";
import Card from "@components/ui/Card.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { faqJsonLd } from "@lib/schema";
import { buildMeta } from "@lib/seo";
import { Icon } from "astro-icon/components";

const home = await getEntry("site", "home");
if (!home) throw new Error("Missing site/home.mdx");
const homeData = home.data;

const faqs = await getCollection("faqItems", (f) => f.data.featured);
const faqItems = faqs
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6)
  .map((f) => ({ id: f.data.id, question: f.data.question, answer: f.data.answer }));

const meta = buildMeta({
  title: homeData.seo.title,
  description: homeData.seo.description,
  path: "/",
});

const jsonLd = [faqJsonLd(faqItems)];
---

<BaseLayout meta={meta} jsonLd={jsonLd}>
  <Hero
    greeting={homeData.greeting}
    h1={homeData.h1}
    subhead={homeData.subhead}
    ctaPrimary={homeData.ctaPrimary}
    ctaSecondary={homeData.ctaSecondary}
    image={{
      src: "https://images.unsplash.com/photo-1584535250253-082add1cd727?auto=format&fit=crop&w=1200&q=80",
      alt: "Train trestle over the James River at golden hour in Richmond, Virginia",
      caption: "Based in RVA. Mobile everywhere in the metro.",
      credit: "Photo, Derrick Brooks / Unsplash",
    }}
  />

  <section class="section-tight bg-[color:var(--color-warm-gray)] border-y border-[color:var(--color-border)]">
    <div class="container-brand grid sm:grid-cols-3 gap-6 text-center">
      <div>
        <Icon name="lucide:shield-check" class="size-6 mx-auto mb-2 text-[color:var(--color-plum)]" />
        <p class="font-display text-xl">Licensed & Insured</p>
        <p class="eyebrow mt-1">VA-commissioned · NNA Certified</p>
      </div>
      <div>
        <Icon name="lucide:clock" class="size-6 mx-auto mb-2 text-[color:var(--color-plum)]" />
        <p class="font-display text-xl">Evenings & Weekends</p>
        <p class="eyebrow mt-1">Standard availability, no premium</p>
      </div>
      <div>
        <Icon name="lucide:map-pin" class="size-6 mx-auto mb-2 text-[color:var(--color-plum)]" />
        <p class="font-display text-xl">Mobile to You</p>
        <p class="eyebrow mt-1">Richmond metro · 50-mile radius</p>
      </div>
    </div>
  </section>

  {/* Warm "meet Morgan" intro. Photos are Unsplash placeholders;
      swap with locally-shot Richmond + portrait photography when ready.
      Uses section-tight so the gap below the credential strip stays
      cozy, not cavernous. */}
  <section class="section-tight">
    <div class="container-brand grid lg:grid-cols-[0.9fr_1.1fr] gap-12 items-center">
      <div class="relative">
        <div class="grid grid-cols-6 grid-rows-6 gap-3 aspect-[4/5] max-w-md mx-auto lg:mx-0">
          <figure class="col-span-4 row-span-4 overflow-hidden rounded-[20px] border border-[color:var(--color-ice-deep)] shadow-[0_20px_50px_rgba(20,26,36,0.12)]">
            <img
              src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?auto=format&fit=crop&w=900&q=80"
              alt="Warm notary-signing moment at a kitchen table"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </figure>
          <figure class="col-span-3 row-span-3 col-start-4 row-start-4 overflow-hidden rounded-[16px] border border-[color:var(--color-ice-deep)] shadow-[0_12px_32px_rgba(20,26,36,0.10)] bg-[color:var(--color-ice)]">
            <img
              src="https://images.unsplash.com/photo-1574362848149-11496d93a7c7?auto=format&fit=crop&w=700&q=80"
              alt="Richmond, Virginia row houses on a quiet tree-lined street"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </figure>
          <figure class="col-span-2 row-span-2 col-start-1 row-start-5 overflow-hidden rounded-[14px] border border-[color:var(--color-ice-deep)] bg-[color:var(--color-warm-white)]">
            <img
              src="https://images.unsplash.com/photo-1527689368864-3a821dbccc34?auto=format&fit=crop&w=500&q=80"
              alt="Fountain pen resting on signed paperwork"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </figure>
        </div>
        <p class="mt-4 text-center lg:text-left text-[11px] font-mono-brand uppercase tracking-widest text-[color:var(--color-text-tertiary)]">
          Placeholder photography · Richmond shoot to come
        </p>
      </div>

      <div class="space-y-5">
        <p class="font-[family-name:var(--font-hand)] text-3xl sm:text-4xl leading-none text-[color:var(--color-plum)]">
          Meet Morgan
        </p>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl leading-tight">
          A neighbor who happens to be a notary.
        </h2>
        <p class="text-[color:var(--color-text-secondary)] text-lg leading-relaxed max-w-xl">
          Signings feel less like paperwork and more like a porch-visit.
          I'll meet you at your kitchen table, your office, a hospital room,
          a coffee shop on Cary Street, wherever the document needs to be.
          Witnesses, printing, a friendly pen, and plenty of patience,
          all included.
        </p>
        <p class="text-[color:var(--color-text-secondary)] text-base max-w-xl">
          Boutique by design. One notary, every time. No call center, no
          queue, no upsell.
        </p>
        <div class="pt-2 flex items-center gap-4">
          <span class="signature">— Morgan</span>
          <a
            href="/about"
            class="text-sm font-medium text-[color:var(--color-plum)] no-underline hover:underline"
          >
            Read my story →
          </a>
        </div>
      </div>
    </div>
  </section>

  <ServicesGrid />

  <section class="section bg-[color:var(--color-warm-gray)]">
    <div class="container-brand grid lg:grid-cols-2 gap-10 items-start">
      <div>
        <SectionHeader eyebrow="Why Morgan" class="mb-6 !max-w-none">
          <h2 class="font-display text-3xl sm:text-4xl">
            Why I built this business, and what it means for you.
          </h2>
        </SectionHeader>
        <div class="prose-brand">
          <p>
            Morgan Danner, Notary isn't a side hustle. I got my Virginia
            commission, my NNA certification, my E&O insurance, and my
            loan-signing training because I wanted to build something that's
            actually mine, and where the quality of the experience is
            entirely up to me.
          </p>
          <p>
            Details are not optional. I come to you, your hospital room,
            your office, your kitchen table. I bring everything I need,
            including a witness if one is required. I pick up the phone.
          </p>
          <p>
            <a href="/about">More about how I work →</a>
          </p>
        </div>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <Card>
          <p class="eyebrow mb-2">Mobile</p>
          <p class="font-display text-lg leading-snug">
            I come to you, your home, office, hospital, or hospice.
          </p>
        </Card>
        <Card>
          <p class="eyebrow mb-2">Remote</p>
          <p class="font-display text-lg leading-snug">
            Virginia-authorized RON. Sign from anywhere in the state.
          </p>
        </Card>
        <Card>
          <p class="eyebrow mb-2">B2B rotation</p>
          <p class="font-display text-lg leading-snug">
            On Snapdocs, NotaryDash, SigningOrder, and more. Add me direct.
          </p>
        </Card>
        <Card variant="dark">
          <p class="eyebrow eyebrow-neon mb-2">The People's Rate</p>
          <p class="font-display text-lg leading-snug text-white">
            Community discount. Honor system. No documentation required.
          </p>
        </Card>
      </div>
    </div>
  </section>

  <AreasGrid />

  <TestimonialsStrip />

  <FaqAccordion items={faqItems} eyebrow="Frequently Asked" title="Good questions. Straight answers." />

  <CtaStrip />
</BaseLayout>
