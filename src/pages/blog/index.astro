---
import { getCollection } from "astro:content";
import Breadcrumb from "@components/sections/Breadcrumb.astro";
import CtaStrip from "@components/sections/CtaStrip.astro";
import Card from "@components/ui/Card.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { breadcrumbJsonLd } from "@lib/schema";
import { absUrl, buildMeta } from "@lib/seo";
import { Icon } from "astro-icon/components";

const posts = (await getCollection("blog", (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const meta = buildMeta({
  title: "Notary Blog — Richmond VA",
  description:
    "Straight-talking guides to mobile notary work, loan signings, apostilles, remote online notarization, and Virginia-specific signing situations.",
  path: "/blog",
});

const jsonLd = [
  breadcrumbJsonLd([
    { name: "Home", url: absUrl("/") },
    { name: "Blog", url: absUrl("/blog") },
  ]),
];

const formatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<BaseLayout meta={meta} jsonLd={jsonLd}>
  <Breadcrumb items={[{ name: "Home", url: "/" }, { name: "Blog", url: "/blog" }]} />

  <section class="section-tight">
    <div class="container-brand max-w-3xl">
      <p class="eyebrow mb-3">The blog</p>
      <h1 class="font-display text-4xl sm:text-5xl">Guides &amp; field notes.</h1>
      <p class="mt-4 text-lg text-[color:var(--color-text-secondary)]">
        Plain-English walkthroughs of things I get asked about often —
        loan-signing day, the apostille process, hospital signings, RON,
        and whatever else is worth writing up.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-brand max-w-3xl space-y-5">
      {
        posts.map((p) => (
          <Card as="article">
            <a href={`/blog/${p.data.slug}`} class="no-underline text-[color:var(--color-text-primary)]">
              <p class="eyebrow">{formatter.format(p.data.publishDate)} · {p.data.readingTime ?? "Read"}</p>
              <h2 class="font-display text-2xl sm:text-3xl mt-2 mb-1">{p.data.title}</h2>
              <p class="text-[color:var(--color-text-secondary)]">{p.data.description}</p>
              <span class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-[color:var(--color-plum)]">
                Read <Icon name="lucide:arrow-right" class="size-4" />
              </span>
            </a>
          </Card>
        ))
      }
    </div>
  </section>

  <CtaStrip />
</BaseLayout>
