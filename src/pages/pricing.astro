---
import { getCollection, getEntry, render } from "astro:content";
import Breadcrumb from "@components/sections/Breadcrumb.astro";
import CtaStrip from "@components/sections/CtaStrip.astro";
import PricingTable from "@components/sections/PricingTable.astro";
import Alert from "@components/ui/Alert.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { breadcrumbJsonLd } from "@lib/schema";
import { absUrl, buildMeta } from "@lib/seo";

const entry = await getEntry("site", "pricing");
if (!entry) throw new Error("Missing site/pricing.mdx");
const { Content } = await render(entry);

const services = await getCollection("services");
const bySlug = (s: string) => services.find((x) => x.data.slug === s);

const generalRows = bySlug("general-mobile-notary")?.data.pricing ?? [];
const loanRows = bySlug("loan-signing")?.data.pricing ?? [];
const estateRows = bySlug("estate-trust")?.data.pricing ?? [];
const ronRows = bySlug("remote-online-notary")?.data.pricing ?? [];
const apostilleRows = bySlug("apostille")?.data.pricing ?? [];

const meta = buildMeta({
  title: entry.data.seo.title,
  description: entry.data.seo.description,
  path: "/pricing",
});

const jsonLd = [
  breadcrumbJsonLd([
    { name: "Home", url: absUrl("/") },
    { name: "Pricing", url: absUrl("/pricing") },
  ]),
];
---

<BaseLayout meta={meta} jsonLd={jsonLd}>
  <Breadcrumb items={[{ name: "Home", url: "/" }, { name: "Pricing", url: "/pricing" }]} />
  <section class="section-tight">
    <div class="container-brand max-w-3xl">
      <p class="eyebrow mb-3">Pricing</p>
      <h1 class="font-display text-4xl sm:text-5xl">{entry.data.h1}</h1>
      <p class="mt-4 text-lg text-[color:var(--color-text-secondary)]">{entry.data.subhead}</p>
    </div>
  </section>

  <PricingTable title="General Mobile Notary" rows={generalRows} />
  <PricingTable title="Loan Signings" rows={loanRows} />
  <PricingTable title="Estate & Trust" rows={estateRows} />
  <PricingTable title="Remote Online Notary (RON)" rows={ronRows} />
  <PricingTable title="Apostille & Authentication" rows={apostilleRows} />

  <section class="section-tight">
    <div class="container-brand max-w-3xl">
      <div class="prose-brand">
        <Content />
      </div>
      <Alert tone="info" title="The People's Rate">
        Qualifying signers get discounted travel and reduced notary fees on
        direct bookings. <a href="/peoples-rate">See eligibility.</a>
      </Alert>
    </div>
  </section>

  <CtaStrip
    heading="Ready to lock it in?"
    body="Text a description of what you need and I'll quote the all-in price before you confirm."
  />
</BaseLayout>
