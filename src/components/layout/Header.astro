---
import { NAP, TEL_HREF } from "@lib/nap";
import { NAV_LINKS } from "@lib/site";
import { Icon } from "astro-icon/components";

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-[color:var(--color-warm-white)]/95 backdrop-blur border-b border-[color:var(--color-border)]">
  <div class="container-brand flex items-center justify-between gap-6 py-4">
    <a
      href="/"
      class="flex items-center gap-3 no-underline text-[color:var(--color-text-primary)]"
      aria-label="Morgan Danner Notary home"
    >
      <span class="inline-flex size-9 items-center justify-center rounded-full bg-[color:var(--color-plum)] text-white font-display text-lg">
        M
      </span>
      <span class="hidden sm:flex flex-col leading-tight">
        <span class="font-display text-lg">Morgan Danner</span>
        <span class="eyebrow">Notary · Richmond, VA</span>
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-6" aria-label="Primary">
      {
        NAV_LINKS.map((l) => {
          const active = pathname === l.href || (l.href !== "/" && pathname.startsWith(l.href));
          return (
            <a
              href={l.href}
              class:list={[
                "text-sm no-underline transition-colors hover:text-[color:var(--color-plum)]",
                active ? "text-[color:var(--color-plum)] font-medium" : "text-[color:var(--color-text-primary)]",
              ]}
            >
              {l.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        class="hidden md:inline-flex btn btn-secondary !py-2 !px-3 !text-sm"
        href={TEL_HREF}
        aria-label={`Call ${NAP.phoneDisplay}`}
      >
        <Icon name="lucide:phone" class="size-4" />
        <span class="font-mono-brand">{NAP.phoneDisplay}</span>
      </a>
      <a class="btn btn-primary !py-2 !px-3 !text-sm" href="/contact">
        Book signing
      </a>
      <button
        type="button"
        class="lg:hidden inline-flex size-10 items-center justify-center rounded-md border border-[color:var(--color-border)] text-[color:var(--color-text-primary)]"
        aria-label="Open menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
        data-menu-button
      >
        <Icon name="lucide:menu" class="size-5" />
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-[color:var(--color-border)] bg-[color:var(--color-warm-white)]"
    data-menu-panel
  >
    <nav class="container-brand py-4 flex flex-col gap-2" aria-label="Mobile">
      {
        NAV_LINKS.map((l) => (
          <a
            href={l.href}
            class="py-2 text-base no-underline text-[color:var(--color-text-primary)] border-b border-[color:var(--color-border)]"
          >
            {l.label}
          </a>
        ))
      }
      <a class="mt-2 btn btn-secondary w-full justify-center" href={TEL_HREF}>
        <Icon name="lucide:phone" class="size-4" />
        <span class="font-mono-brand">{NAP.phoneDisplay}</span>
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  (() => {
    const btn = document.querySelector("[data-menu-button]");
    const panel = document.querySelector("[data-menu-panel]");
    if (!btn || !panel) return;
    btn.addEventListener("click", () => {
      const open = panel.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", String(open));
    });
  })();
</script>
