---
interface Props {
  eyebrow?: string;
  align?: "left" | "center";
  class?: string;
}
const { eyebrow, align = "left", class: className = "" } = Astro.props;
---

<div class={`${align === "center" ? "text-center mx-auto max-w-3xl" : "max-w-3xl"} ${className}`}>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <slot />
</div>
