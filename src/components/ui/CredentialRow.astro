---
import { NAP } from "@lib/nap";
type Variant = "dark" | "light";
interface Props {
  items?: readonly string[];
  class?: string;
  variant?: Variant;
}
const {
  items = NAP.credentials,
  class: className = "",
  variant = "dark",
} = Astro.props as Props;

// On dark surfaces the neon pop reads as a "vacancy sign" highlight.
// On light surfaces the same neon drops to ~1.3:1 contrast, unreadable
// and a WCAG AA fail, so we switch to deep plum text instead.
const rowColor =
  variant === "dark"
    ? "text-[color:var(--color-neon)]"
    : "text-[color:var(--color-plum)]";
const sepColor =
  variant === "dark"
    ? "text-[color:var(--color-neon)]/40"
    : "text-[color:var(--color-plum)]/35";
const dotColor =
  variant === "dark"
    ? "bg-[color:var(--color-neon)]"
    : "bg-[color:var(--color-emerald)]";
---

<div class={`flex flex-wrap items-center gap-x-6 gap-y-2 ${className}`}>
  {
    items.map((item, i) => (
      <>
        <span class={`credential-row flex items-center gap-2 ${rowColor}`}>
          {i === 0 && (
            <span
              class={`pulse-dot ${dotColor}`}
              aria-hidden="true"
            />
          )}
          {item}
        </span>
        {i < items.length - 1 && (
          <span class={`credential-row ${sepColor}`} aria-hidden="true">
            ·
          </span>
        )}
      </>
    ))
  }
</div>
