---
import { NAP } from "@lib/nap";
interface Props {
  items?: readonly string[];
  class?: string;
}
const { items = NAP.credentials, class: className = "" } = Astro.props;
---

<div class={`flex flex-wrap items-center gap-x-6 gap-y-2 ${className}`}>
  {
    items.map((item, i) => (
      <>
        <span class="credential-row flex items-center gap-2">
          {i === 0 && <span class="pulse-dot" aria-hidden="true" />}
          {item}
        </span>
        {i < items.length - 1 && (
          <span class="credential-row text-[color:var(--color-neon)]/40" aria-hidden="true">
            ·
          </span>
        )}
      </>
    ))
  }
</div>
