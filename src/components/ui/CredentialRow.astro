---
import { NAP } from "@lib/nap";
type Variant = "dark" | "light";
interface Props {
  items?: readonly string[];
  class?: string;
  variant?: Variant;
}
const { items = NAP.credentials, class: className = "", variant = "dark" } = Astro.props as Props;

// Each credential gets its own visible 8px dot so the row scans as
// a "vacancy sign" even at small sizes. First dot pulses, the rest
// are static. On dark surfaces we use ice-blue (cool accent) so it
// pops; on light surfaces we use emerald for AA contrast.
const rowColor =
  variant === "dark" ? "text-[color:var(--color-neon)]" : "text-[color:var(--color-plum)]";
const dotColor =
  variant === "dark" ? "bg-[color:var(--color-neon)]" : "bg-[color:var(--color-emerald)]";
---

<div class={`flex flex-wrap items-center gap-x-5 gap-y-2 ${className}`}>
  {
    items.map((item, i) => (
      <span class={`credential-row flex items-center gap-2 ${rowColor}`}>
        {i === 0 ? (
          <span class={`pulse-dot ${dotColor}`} aria-hidden="true" />
        ) : (
          <span class={`dot-static ${dotColor}`} aria-hidden="true" />
        )}
        {item}
      </span>
    ))
  }
</div>
