---
interface Props {
  attribution?: string;
  class?: string;
}
const { attribution, class: className = "" } = Astro.props;
---

<figure class={`my-8 ${className}`}>
  <blockquote class="pull-quote">
    <slot />
  </blockquote>
  {
    attribution && (
      <figcaption class="mt-3 ml-4 text-sm text-[color:var(--color-text-secondary)] font-mono-brand uppercase tracking-wider">
       , {attribution}
      </figcaption>
    )
  }
</figure>
