---
import Button from "@components/ui/Button.astro";
import CredentialRow from "@components/ui/CredentialRow.astro";
import { NAP, TEL_HREF } from "@lib/nap";
import { Icon } from "astro-icon/components";

interface Props {
  heading?: string;
  body?: string;
}
const {
  heading = "Need someone today? Call or text.",
  body = "I respond within the hour during service hours. No autoresponders. No phone trees. Just me.",
} = Astro.props;
---

<section class="section">
  <div class="container-brand">
    <div class="card card-dark relative overflow-hidden p-10 sm:p-14">
      <div class="absolute -top-16 -right-16 size-64 rounded-full bg-[color:var(--color-plum)] opacity-30 blur-3xl" aria-hidden="true"></div>
      <div class="relative grid lg:grid-cols-[2fr_1fr] gap-8 items-end">
        <div class="space-y-4">
          <CredentialRow />
          <h2 class="font-display text-3xl sm:text-4xl text-white max-w-2xl">{heading}</h2>
          <p class="text-white/70 max-w-xl">{body}</p>
        </div>
        <div class="flex flex-col gap-3">
          <Button variant="dark" href={TEL_HREF}>
            <Icon name="lucide:phone" class="size-4" />
            <span>{NAP.phoneDisplay}</span>
          </Button>
          <Button variant="primary" href="/contact">
            Book online
            <Icon name="lucide:arrow-right" class="size-4" />
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
