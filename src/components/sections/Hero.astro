---
import Button from "@components/ui/Button.astro";
import CredentialRow from "@components/ui/CredentialRow.astro";
import ResponseTime from "@components/ui/ResponseTime.astro";
import { Icon } from "astro-icon/components";

interface Props {
  eyebrow?: string;
  /** Handwritten greeting rendered above the H1 in Caveat script. */
  greeting?: string;
  h1: string;
  subhead?: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  variant?: "dark" | "light";
  /** Optional Richmond photo for the right-hand aside. Falls back to
   *  the gradient card when omitted. */
  image?: {
    src: string;
    alt: string;
    caption?: string;
    credit?: string;
  };
}
const {
  eyebrow,
  greeting,
  h1,
  subhead,
  ctaPrimary,
  ctaSecondary,
  variant = "dark",
  image,
} = Astro.props as Props;

const isDark = variant === "dark";
---

<section
  class:list={[
    "relative overflow-hidden",
    isDark
      ? "bg-[color:var(--color-charcoal)]"
      : "bg-[color:var(--color-warm-white)] grain",
  ]}
>
  <div class="container-brand section grid lg:grid-cols-[1.2fr_1fr] gap-10 items-center">
    <div class="space-y-6 lg:max-w-2xl">
      <CredentialRow variant={variant} />
      {eyebrow && (
        <p
          class:list={[
            "eyebrow",
            isDark ? "text-[color:var(--color-neon)]" : "eyebrow-terracotta",
          ]}
        >
          {eyebrow}
        </p>
      )}
      {greeting && (
        <p
          class:list={[
            "font-[family-name:var(--font-hand)] text-3xl sm:text-4xl leading-none -mb-1",
            isDark
              ? "text-[color:var(--color-neon)]"
              : "text-[color:var(--color-plum)]",
          ]}
        >
          {greeting}
        </p>
      )}
      <h1
        class:list={[
          "font-display text-4xl sm:text-5xl lg:text-6xl hero-h1",
          isDark ? "text-white" : "text-[color:var(--color-text-primary)]",
        ]}
      >
        {h1}
      </h1>
      {
        subhead && (
          <p
            class:list={[
              "text-lg max-w-xl",
              isDark ? "text-white/80" : "text-[color:var(--color-text-secondary)]",
            ]}
          >
            {subhead}
          </p>
        )
      }
      <div class="flex flex-wrap items-center gap-3 pt-2">
        {ctaPrimary && <Button variant="primary" href={ctaPrimary.href}>{ctaPrimary.label}<Icon name="lucide:arrow-right" class="size-4" /></Button>}
        {ctaSecondary && <Button variant={isDark ? "dark" : "secondary"} href={ctaSecondary.href}>{ctaSecondary.label}</Button>}
        <ResponseTime />
      </div>
    </div>

    <div class="hidden lg:block">
      <slot name="aside">
        {
          image ? (
            <figure class="relative aspect-[4/5] rounded-[20px] overflow-hidden border border-[color:var(--color-border-warm)] shadow-[0_20px_50px_rgba(28,26,24,0.12)]">
              <img
                src={image.src}
                alt={image.alt}
                width="800"
                height="1000"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="absolute inset-0 h-full w-full object-cover"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-[rgba(28,26,24,0.55)] via-transparent to-transparent"
                aria-hidden="true"
              />
              {(image.caption || image.credit) && (
                <figcaption class="absolute inset-x-0 bottom-0 p-5 text-white">
                  {image.caption && (
                    <p class="font-display text-2xl leading-tight drop-shadow-sm">
                      {image.caption}
                    </p>
                  )}
                  {image.credit && (
                    <p class="mt-1 eyebrow text-white/75">{image.credit}</p>
                  )}
                </figcaption>
              )}
            </figure>
          ) : (
            <div class="aspect-[4/5] rounded-[20px] border border-white/10 bg-gradient-to-br from-[color:var(--color-plum)] to-[color:var(--color-terracotta)] p-6 relative overflow-hidden">
              <div class="absolute inset-0 opacity-20 mix-blend-overlay bg-[radial-gradient(circle_at_30%_20%,white,transparent_50%)]" />
              <div class="relative h-full flex flex-col justify-end">
                <p class="font-display text-white text-3xl leading-tight">
                  Mobile. Remote. Apostille.
                </p>
                <p class="mt-2 eyebrow text-[color:var(--color-cream)]">
                  Evenings · Weekends · Same-day
                </p>
              </div>
            </div>
          )
        }
      </slot>
    </div>
  </div>
</section>
